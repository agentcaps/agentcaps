---
import Base from '../../layouts/Base.astro';
import { Button, CapCard, KV, Notice, Score, ValidationFinding } from '@agentcaps/ui';
import type { KVItem } from '@agentcaps/ui';
import { getListings, hostedCatalogPath } from '../../lib/registry';

const all = getListings();

export function getStaticPaths() {
  return getListings().map((listing) => ({ params: { slug: listing.slug }, props: { listing } }));
}

const { listing } = Astro.props;
const entry = listing.catalogEntry;
const category = listing.source.curation?.category ?? 'capability';
const catalogJson = JSON.stringify(entry, null, 2);
const hostedCatalog = hostedCatalogPath(listing.source.url);
const v = listing.validation;
const findings = [
  ...v.errors.map((f) => ({ ...f, severity: 'error' as const })),
  ...v.warnings.map((f) => ({ ...f, severity: 'warning' as const })),
  ...v.info.map((f) => ({ ...f, severity: 'info' as const }))
];
const queries = entry.representativeQueries ?? [];
const capabilities = entry.capabilities ?? [];
const tags = entry.tags ?? [];
const snapshotItems: KVItem[] = [
  { label: 'path', value: listing.snapshot.artifactPath },
  { label: 'commit', value: (listing.snapshot.sourceCommit ?? '—').slice(0, 12) },
  { label: 'indexed', value: listing.snapshot.fetchedAt.slice(0, 10) }
];

// Related: same-category first, then tag overlap, then score. Top 3.
const myTags = new Set(tags.map((t) => t.toLowerCase()));
const related = all
  .filter((l) => l.slug !== listing.slug)
  .map((l) => {
    const lTags = (l.catalogEntry.tags ?? []).map((t) => t.toLowerCase());
    return {
      l,
      same: (l.source.curation?.category ?? 'capability') === category ? 1 : 0,
      overlap: lTags.filter((t) => myTags.has(t)).length,
      score: l.validation.score
    };
  })
  .sort((a, b) => b.same - a.same || b.overlap - a.overlap || b.score - a.score)
  .slice(0, 3)
  .map((x) => x.l);
---
<Base title={`${entry.displayName} — AgentCaps`} description={entry.description}>
  <section class="section section--flush">
    <a class="back" href="/explore">← Explore</a>
    <span class="cap-cat detail-cat">{category} · indexed from GitHub</span>
    <h1>{entry.displayName}</h1>
    <p class="prose lede">{entry.description}</p>
    <div class="btn-row detail-actions">
      <Button variant="primary" class="js-copy">Copy CatalogEntry</Button>
      <Button href={listing.source.url} rel="noreferrer">Open GitHub</Button>
      {hostedCatalog && <Button href={hostedCatalog}>Hosted ai-catalog.json</Button>}
    </div>
    <Notice label="Note">Not publisher verified. The validation score measures ARD metadata quality, not safety or trust.</Notice>
  </section>

  <section class="section detail-grid">
    <div class="detail-main">
      {queries.length > 0 && (
        <div class="block">
          <h2>What you'd ask for</h2>
          <ul class="query-list">{queries.map((q) => <li>{q}</li>)}</ul>
        </div>
      )}

      {capabilities.length > 0 && (
        <div class="block">
          <h2>Capabilities</h2>
          <div class="tagrow tagrow--lg">{capabilities.map((c) => <span class="tag mono">{c}</span>)}</div>
        </div>
      )}

      <div class="block">
        <h2>Validation report</h2>
        <p class="block-sub">{v.summary}</p>
        <ul class="findings">
          {findings.map((f) => <ValidationFinding severity={f.severity} code={f.code} message={f.message} />)}
        </ul>
      </div>

      <div class="block">
        <details class="json">
          <summary><span>CatalogEntry JSON</span><span class="mono json-hint">standard ARD fields only</span></summary>
          <pre id="catalog-json"><code>{catalogJson}</code></pre>
        </details>
      </div>
    </div>

    <aside class="detail-side">
      <div class="score-card">
        <Score value={v.score} variant="big" />
        <p>ARD metadata completeness &amp; search readiness.</p>
      </div>

      {tags.length > 0 && (
        <div class="side-block">
          <h3 class="label">Tags</h3>
          <div class="tagrow">
            {tags.map((t) => <a class="tag tag--link" href={`/explore?q=${encodeURIComponent(t)}`}>{t}</a>)}
          </div>
        </div>
      )}

      <div class="side-block">
        <h3 class="label">Source snapshot</h3>
        <KV items={snapshotItems} />
        <div class="btn-row" style="margin-top: 12px;">
          {listing.snapshot.sourceWebUrl && <Button variant="ghost" href={listing.snapshot.sourceWebUrl} rel="noreferrer">Pinned source →</Button>}
          <Button variant="ghost" href={listing.snapshot.rawArtifactUrl} rel="noreferrer">Raw artifact →</Button>
        </div>
      </div>
    </aside>
  </section>

  {related.length > 0 && (
    <section class="section related">
      <h2>Related capabilities</h2>
      <div class="cap-grid">
        {related.map((r) => (
          <CapCard
            name={r.catalogEntry.displayName}
            href={`/skills/${r.slug}`}
            description={r.catalogEntry.description}
            category={r.source.curation?.category ?? 'capability'}
            score={r.validation.score}
            tags={r.catalogEntry.tags ?? []}
          />
        ))}
      </div>
    </section>
  )}

  <div class="toast" id="toast" role="status" aria-live="polite">Copied CatalogEntry to clipboard</div>

  <script define:vars={{ catalogJson }}>
    const btn = document.querySelector('.js-copy');
    const toast = document.querySelector('#toast');
    let timer;
    btn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(catalogJson);
        toast?.classList.add('show');
        clearTimeout(timer);
        timer = setTimeout(() => toast?.classList.remove('show'), 1800);
      } catch {
        btn.textContent = 'Copy failed';
      }
    });
  </script>

  <style>
    .back { font: 600 0.8125rem/1 var(--font-sans); color: var(--ink-2); }
    .detail-cat { display: block; margin: 22px 0 12px; }
    .detail-actions { margin-top: 24px; }
    .lede { font-size: clamp(1.0625rem, 1rem + 0.5vw, 1.375rem); margin-top: 12px; }
    .notice { margin-top: 18px; max-width: 70ch; }

    .detail-grid { display: grid; grid-template-columns: minmax(0, 1fr) 340px; gap: 40px; align-items: start; }
    .detail-main { display: grid; gap: 36px; }
    .block h2 { margin-bottom: 14px; }
    .block-sub { color: var(--muted); font-size: 0.875rem; margin-bottom: 14px; max-width: 68ch; }

    .query-list { margin: 0; padding: 0; list-style: none; display: grid; gap: 0; border: 1px solid var(--line); border-radius: 4px; overflow: hidden; }
    .query-list li { padding: 12px 16px; border-top: 1px solid var(--line); color: var(--ink-2); font-size: 0.9375rem; }
    .query-list li:first-child { border-top: 0; }
    .query-list li::before { content: '“'; color: var(--accent-ink); margin-right: 2px; }
    .query-list li::after { content: '”'; color: var(--accent-ink); }

    .json summary { cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 12px 14px; border: 1px solid var(--line); border-radius: 4px; font-weight: 600; font-size: 0.9375rem; }
    .json[open] summary { border-bottom-left-radius: 0; border-bottom-right-radius: 0; }
    .json summary::-webkit-details-marker { display: none; }
    .json-hint { color: var(--muted); font-weight: 400; font-size: 0.75rem; }
    .json pre { border-top: 0; border-top-left-radius: 0; border-top-right-radius: 0; }

    .detail-side { display: grid; gap: 24px; position: sticky; top: 84px; }
    .score-card { border: 1px solid var(--line); border-radius: 4px; padding: 20px; background: var(--surface); }
    .score-card p { margin-top: 10px; font-size: 0.8125rem; color: var(--muted); }
    .side-block h3.label { margin-bottom: 10px; }
    .tag--link { cursor: pointer; }
    .tag--link:hover { border-color: var(--ink-2); color: var(--ink); text-decoration: none; }

    .related h2 { margin-bottom: 22px; }

    .toast {
      position: fixed; left: 50%; bottom: 28px; transform: translateX(-50%) translateY(8px);
      background: var(--ink); color: #fff; font: 600 0.875rem/1 var(--font-sans);
      padding: 13px 18px; border-radius: 999px; z-index: 60;
      opacity: 0; pointer-events: none;
      transition: opacity 0.18s var(--ease), transform 0.18s var(--ease);
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    @media (max-width: 900px) {
      .detail-grid { grid-template-columns: 1fr; gap: 32px; }
      .detail-side { position: static; }
    }
    @media (prefers-reduced-motion: reduce) {
      .toast { transition: opacity 0.18s; transform: translateX(-50%); }
    }
  </style>
</Base>
