---
import Base from '../layouts/Base.astro';
import SearchField from '../components/SearchField.tsx';
import CapabilityResults from '../components/CapabilityResults.tsx';
import type { CapItem } from '../components/CapabilityResults.tsx';
import { getListings, hostedCatalogPath } from '../lib/registry';

const listings = getListings();

const items: CapItem[] = listings.map((listing) => {
  const entry = listing.catalogEntry;
  return {
    slug: listing.slug,
    name: entry.displayName,
    href: `/skills/${listing.slug}`,
    description: entry.description,
    category: listing.source.curation?.category ?? 'capability',
    score: listing.validation.score,
    tags: entry.tags ?? [],
    githubUrl: listing.source.url,
    hostedHref: hostedCatalogPath(listing.source.url),
    haystack: [
      entry.displayName,
      entry.description,
      ...(entry.tags ?? []),
      ...(entry.capabilities ?? []),
      ...(entry.representativeQueries ?? [])
    ].join(' ').toLowerCase()
  };
});
---
<Base
  title="Explore — AgentCaps Registry"
  description="Search the full index of curated agent capabilities. Scores measure ARD metadata quality and search relevance only."
  active="explore"
>
  <section class="section section--flush">
    <h1>Explore the registry.</h1>
    <p class="prose lede">
      Search across generated metadata from curated GitHub <code>SKILL.md</code> projects and
      collection repos. Scores measure metadata quality, not safety or trust.
    </p>
    <SearchField
      client:load
      class="explore-search"
      autofocus
      placeholder="browser automation, memory recall, pptx slides…"
    />
  </section>

  <section class="section">
    <CapabilityResults client:load items={items} layout="list" showCount countNoun="capabilities" />
  </section>

  <style>
    .explore-search { margin-top: 26px; max-width: 680px; }
    .results-count { margin-bottom: 18px; }
    .lede { font-size: clamp(1.0625rem, 1rem + 0.5vw, 1.375rem); margin-top: 16px; }
  </style>
</Base>
