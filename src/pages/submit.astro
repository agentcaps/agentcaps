---
import Base from '../layouts/Base.astro';
import SubmitApp from '../components/SubmitApp.tsx';
---
<Base
  title="Submit a SKILL.md — AgentCaps"
  description="Paste a GitHub SKILL.md link, parse it into a standard ARD CatalogEntry, review, and submit it to the AgentCaps registry."
  active="submit"
>
  <section class="section section--flush">
    <SubmitApp client:load />
  </section>

  <style is:global>
    .submit-wrap { max-width: 780px; margin: 0 auto; }

    /* Stepper */
    .stepper { display: flex; list-style: none; margin: 0 0 40px; padding: 0; }
    .stepper .step { flex: 1; position: relative; display: flex; flex-direction: column; align-items: center; gap: 8px; }
    .stepper .step:not(:first-child)::before {
      content: ''; position: absolute; top: 13px; left: -50%; width: 100%; height: 2px;
      background: var(--line); z-index: 0;
    }
    .stepper .step--active:not(:first-child)::before,
    .stepper .step--done:not(:first-child)::before { background: var(--accent); }
    .step-dot {
      position: relative; z-index: 1; width: 28px; height: 28px; border-radius: 999px;
      display: grid; place-items: center; font: 600 0.8125rem/1 var(--font-mono);
      background: var(--surface); border: 1px solid var(--line-2); color: var(--muted);
    }
    .step--active .step-dot { background: var(--ink); border-color: var(--ink); color: #fff; }
    .step--done .step-dot { background: var(--accent); border-color: var(--accent); color: #fff; }
    .step-label { font-size: 0.8125rem; color: var(--muted); }
    .step--active .step-label, .step--done .step-label { color: var(--ink); }

    .stage { display: grid; gap: 18px; }
    .stage .lede { font-size: 1.125rem; color: var(--ink-2); }

    /* URL field */
    .url-row { display: flex; gap: 10px; flex-wrap: wrap; align-items: stretch; }
    .url-field {
      flex: 1; min-width: 280px; display: flex; align-items: center;
      border: 1px solid var(--line-2); border-radius: 4px; background: var(--surface);
      transition: border-color 0.15s var(--ease), box-shadow 0.15s var(--ease);
    }
    .url-field:focus-within { border-color: var(--ink); box-shadow: 0 0 0 3px var(--accent-bg); }
    .url-prefix { padding-left: 14px; color: var(--muted); font-size: 0.9375rem; }
    .url-field input { flex: 1; border: 0; outline: none; background: none; font: 500 1rem/1 var(--font-sans); color: var(--ink); padding: 14px 14px 14px 6px; }

    .examples { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; }
    .ex-try { color: var(--muted); font-size: 0.75rem; }
    .ex-chip { white-space: nowrap; cursor: pointer; font: 500 0.8125rem/1 var(--font-mono); color: var(--ink-2); background: var(--surface); border: 1px solid var(--line); border-radius: 999px; padding: 7px 12px; transition: border-color 0.15s var(--ease), color 0.15s var(--ease); }
    .ex-chip:hover { border-color: var(--ink); color: var(--ink); }

    /* Loading */
    .loading { display: grid; justify-items: center; gap: 16px; padding: 80px 0; }
    .loading .mono { color: var(--muted); font-size: 0.9375rem; }
    .spinner { width: 30px; height: 30px; border: 3px solid var(--line); border-top-color: var(--accent); border-radius: 999px; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Preview entry card */
    .entry-card { border: 1px solid var(--line); border-radius: 4px; padding: 24px; background: var(--surface); display: grid; gap: 16px; }
    .entry-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .entry-card h2 { margin: 0; }
    .entry-desc { color: var(--ink-2); font-size: 0.9375rem; }
    .q-list { margin: 0; padding: 0; list-style: none; border: 1px solid var(--line); border-radius: 4px; overflow: hidden; }
    .q-list li { padding: 11px 14px; border-top: 1px solid var(--line); color: var(--ink-2); font-size: 0.9375rem; }
    .q-list li:first-child { border-top: 0; }
    .q-list li::before { content: '“'; color: var(--accent-ink); }
    .q-list li::after { content: '”'; color: var(--accent-ink); }

    /* Success */
    .success { justify-items: start; }
    .success-badge { width: 44px; height: 44px; border-radius: 999px; background: var(--accent); color: #fff; display: grid; place-items: center; font-size: 1.4rem; }

    @media (prefers-reduced-motion: reduce) { .spinner { animation-duration: 2s; } }
  </style>
</Base>
