---
import Base from '../layouts/Base.astro';
import { Button, Step, Steps } from '@agentcaps/ui';
import SearchField from '../components/SearchField.tsx';
import CapabilityResults from '../components/CapabilityResults.tsx';
import type { CapItem } from '../components/CapabilityResults.tsx';
import { getListings, getCatalog, hostedCatalogPath } from '../lib/registry';

const listings = getListings();
const catalog = getCatalog();
const tagCount = new Set(listings.flatMap((l) => l.catalogEntry.tags ?? [])).size;
const sourceCount = new Set(listings.map((l) => l.source.url)).size;

const items: CapItem[] = listings.map((listing) => {
  const entry = listing.catalogEntry;
  return {
    slug: listing.slug,
    name: entry.displayName,
    href: `/skills/${listing.slug}`,
    description: entry.description,
    category: listing.source.curation?.category ?? 'capability',
    score: listing.validation.score,
    tags: entry.tags ?? [],
    hostedHref: hostedCatalogPath(listing.source.url),
    haystack: [
      entry.displayName,
      entry.description,
      ...(entry.tags ?? []),
      ...(entry.capabilities ?? []),
      ...(entry.representativeQueries ?? [])
    ].join(' ').toLowerCase()
  };
});
---
<Base
  title="AgentCaps — Search agent capabilities by what they do"
  description="A searchable index of ARD CatalogEntries generated from curated GitHub SKILL.md projects, powered by AgentCaps Registry."
>
  <section class="section section--flush hero">
    <div class="hero-copy">
      <a class="ard-badge rise" href="https://github.com/agentcaps/registry#readme" rel="noreferrer">
        <span class="ard-dot"></span>ARD Compatible
      </a>
      <h1 class="rise rise-1">Find agent skills by what they can do.</h1>
      <p class="prose lede rise rise-2">
        A searchable index of ARD <code>CatalogEntries</code> generated from curated GitHub
        <code>SKILL.md</code> projects, including single-skill repos and collections like
        <code>anthropics/skills</code>.
      </p>
      <SearchField
        client:load
        class="hero-search rise rise-3"
        autofocus
        placeholder="pdf, browser automation, frontend design, slides…"
      />
      <div class="stat-strip rise rise-3">
        <span><b>{catalog.entries.length}</b> capabilities</span>
        <span><b>{sourceCount}</b> GitHub sources</span>
        <span><b>{tagCount}</b> tags</span>
      </div>
    </div>
  </section>

  <section class="section">
    <CapabilityResults client:load items={items} layout="grid" heading="Live index" />
  </section>

  <section class="section">
    <div class="section-head"><h2>Host your own SKILL.md</h2></div>
    <Steps>
      <Step n={1} title="Point to SKILL.md">
        A single GitHub repo, a direct <code>SKILL.md</code> URL, or a collection pattern like <code>skills/*/SKILL.md</code>.
      </Step>
      <Step n={2} title="Generate ARD">
        AgentCaps Registry converts each source into a standard <code>CatalogEntry</code> plus a validation report.
      </Step>
      <Step n={3} title="Host for discovery">
        The registry exposes the global catalog and repo-scoped URLs at <code>/@owner/repo/ai-catalog.json</code>.
      </Step>
    </Steps>
    <div class="btn-row" style="margin-top: 22px;">
      <Button variant="primary" href="https://github.com/agentcaps/agentcaps/issues/new?template=submit-skill.yml" rel="noreferrer">Submit a SKILL.md</Button>
      <Button href="https://github.com/agentcaps/registry" rel="noreferrer">Run the registry engine</Button>
    </div>
  </section>

  <style>
    .hero { padding-top: clamp(48px, 7vw, 96px); padding-bottom: clamp(32px, 5vw, 64px); }
    .hero-copy { max-width: 880px; }
    .ard-badge {
      display: inline-flex; align-items: center; gap: 7px;
      font: 500 0.8125rem/1 var(--font-mono); letter-spacing: 0.01em;
      color: var(--accent-ink); text-decoration: none;
      border: 1px solid var(--accent); border-radius: 999px;
      padding: 5px 12px 5px 9px; margin-bottom: 20px;
      transition: background 0.15s var(--ease), color 0.15s var(--ease);
    }
    .ard-badge:hover { background: var(--accent-bg); }
    .ard-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--accent); flex-shrink: 0;
    }
    .lede { font-size: clamp(1.0625rem, 1rem + 0.5vw, 1.375rem); color: var(--ink-2); margin-top: 22px; }
    .hero-search { margin-top: 30px; max-width: 640px; }
    .stat-strip {
      display: flex; flex-wrap: wrap; gap: 26px; margin-top: 22px;
      font-family: var(--font-mono); font-size: 0.8125rem; color: var(--muted);
    }
    .stat-strip b { color: var(--ink); font-weight: 600; font-size: 1rem; }
  </style>
</Base>
